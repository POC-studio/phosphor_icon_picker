{
  "name": "Lucide Icon Picker",
  "use_bubble_size": true,
  "events": ["icon_selected"],
  "autobinding_property": "value",
  "properties": {
    "initial_icon": {
      "type": "text",
      "default": "smile"
    },
    "value": {
      "type": "text",
      "default": ""
    },
    "stroke_width": {
      "type": "text",
      "default": "2"
    },
    "color": {
      "type": "text",
      "default": "#000000"
    },
    "search_placeholder": {
      "type": "text",
      "default": "Search..."
    },
    "allowed_icons": {
      "type": "long_text",
      "default": ""
    }
  }
}
