{
  "name": "Lucide Icon Picker",
  "events": ["icon_selected"],
  "autobinding_property": "initial_icon",
  "properties": {
    "initial_icon": {
      "type": "text",
      "default": "smile",
      "auto_binding": true
    },
    "stroke_width": {
      "type": "text",
      "default": "2"
    },
    "color": {
      "type": "text",
      "default": "#000000"
    },
    "search_placeholder": {
      "type": "text",
      "default": "Search..."
    },
    "allowed_icons": {
      "type": "long_text",
      "default": ""
    }
  }
}
