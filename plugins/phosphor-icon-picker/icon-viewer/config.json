{
  "name": "Phosphor Icon Viewer",
  "events": ["is_clicked"],
  "properties": {
    "initial_icon": {
      "type": "text",
      "default": "smiley"
    },
    "style": {
      "type": "dropdown",
      "options": ["regular", "thin", "light", "bold", "fill", "duotone"],
      "default": "regular"
    },
    "color": {
      "type": "text",
      "default": "#333333"
    }
  }
}
