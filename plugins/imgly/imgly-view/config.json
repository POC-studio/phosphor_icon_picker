"},{\"image_url\":\"https://images.unsplash.com/photo-1500534314209-a25ddb2bd429?w=400&auto=format&fit=crop&q=80\",\"contributor\":\"Adam Kool\"},{\"image_url\":\"https://images.unsplash.com/photo-1523712999610-f77fbcfc3843?w=400&auto=format&fit=crop&q=80\",\"contributor\":\"Johannes Plenio\"},{\"image_url\":\"https://images.unsplash.com/photo-1511884642898-4c92249e20b6?w=400&auto=format&fit=crop&q=80\",\"contributor\":\"Klemen Vrankar\"}]}"
    },
    "images": {
      "label": "Images d’équipe (liste d’images Bubble)",
      "type": "image",
      "is_list": true
    },
    "image_fetch_api_slug": {
      "label": "Slug API Workflow get_image (fetch CDN → base64)",
      "type": "text",
      "default": "get_image"
    }
  },
  "actions": [
    {
      "id": "create_page_previews",
      "label": "Créer les previews",
      "type": "run_script",
      "file": "actions/create-page-previews.js"
    },
    {
      "id": "export_pdf",
      "label": "Exporter le PDF",
      "type": "run_script",
      "file": "actions/export-pdf.js"
    },
    {
      "id": "save_document",
      "label": "Enregistrer le document",
      "type": "run_script",
      "file": "actions/save-document.js"
    }
  ]
}
