{
  "name": "IMG.LY View",
  "use_bubble_size": false,
  "events": [
    "json_changed",
    "pdf_ready",
    "trimed_pdf_ready",
    "image_uploaded",
    "contribution_added",
    "page_previews_ready",
    "document_saved"
  ],
  "states": {
    "canvas_json": {
      "label": "JSON de la scène CE.SDK (publié à l’enregistrement)",
      "type": "text"
    },
    "pdf_url": {
      "label": "URL du PDF (Bubble, après upload)",
      "type": "text"
    },
    "trimed_pdf_url": {
      "label": "URL du PDF trimé pour l’imprimeur (Bubble, après upload)",
      "type": "text"
    },
    "image_uploaded_url": {
      "label": "URL de la dernière image uploadée (sidebar Images)",
      "type": "text"
    },
    "contribution_id": {
      "label": "ID de la dernière contribution (bookmark)",
      "type": "text"
    },
    "page_previews": {
      "label": "Previews des demi-pages (URLs, ordre naturel)",
      "type": "text",
      "is_list": true
    },
    "unsaved_changes": {
      "label": "Modifications non enregistrées",
      "type": "boolean"
    },
    "margins_warning": {
      "label": "Éléments dans les marges de sécurité (5 mm)",
      "type": "boolean"
    }
  },
  "properties": {
    "document_title": {
      "label": "Document title",
      "type": "text",
      "default": "Document title"
    },
    "pages": {
      "label": "Nombre de feuilles",
      "type": "number",
      "default": 1
    },
    "initial_json": {
      "label": "Initial canvas JSON (sandbox — ignoré si canvas_json est défini)",
      "type": "long_text",
      "default": ""
    },
    "canvas_json": {
      "label": "Canvas JSON (persistance — lier au champ Bubble sauvegardé)",
      "type": "long_text",
      "default": ""
    },
    "bookmarks_json": {
      "label": "Bookmarks (JSON) — { \"bookmarks\": [{ \"image_url\": \"…\", \"contributor\": \"…\" }] }",
      "type": "long_text",
      "default": "{\"bookmarks\":[{\"image_url\":\"https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=400&auto=format&fit=crop&q=80\",\"contributor\":\"Yannick Pulver\"},{\"image_url\":\"https://images.unsplash.com/photo-1472214103451-9374bd1c798e?w=400&auto=format&fit=crop&q=80\",\"contributor\":\"Robert Lukeman\"},{\"image_url\":\"https://images.unsplash.com/photo-1441974231531-c6227db76b6e?w=400&auto=format&fit=crop&q=80\",\"contributor\":\"Lukasz Szmigiel\"},{\"image_url\":\"https://images.unsplash.com/photo-1469474968028-56623f02e42e?w=400&auto=format&fit=crop&q=80\",\"contributor\":\"David Marcu\"},{\"image_url\":\"https://images.unsplash.com/photo-1426604966848-d7adac402bff?w=400&auto=format&fit=crop&q=80\",\"contributor\":\"Adam Kool\"},{\"image_url\":\"https://images.unsplash.com/photo-1470071459604-3b5ec3a7fe05?w=400&auto=format&fit=crop&q=80\",\"contributor\":\"Vadim Sherbakov\"},{\"image_url\":\"https://images.unsplash.com/photo-1447752875215-b2761acb3c5d?w=400&auto=format&fit=crop&q=80\",\"contributor\":\"James Wheeler\"},{\"image_url\":\"https://images.unsplash.com/photo-1518837695005-2083093ee35b?w=400&auto=format&fit=crop&q=80\",\"contributor\":\"Matthew Hamilton\"},{\"image_url\":\"https://images.unsplash.com/photo-1501785888041-af3ef285b470?w=400&auto=format&fit=crop&q=80\",\"contributor\":\"Hendrik Morkel\"},{\"image_url\":\"https://images.unsplash.com/photo-1433086966358-54859d0ed716?w=400&auto=format&fit=crop&q=80\",\"contributor\":\"Luca Bravo\"},{\"image_url\":\"https://images.unsplash.com/photo-1465146344425-f00d5f5c8a07?w=400&auto=format&fit=crop&q=80\",\"contributor\":\"Henry Be\"},{\"image_url\":\"https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?w=400&auto=format&fit=crop&q=80\",\"contributor\":\"Ramon Kagie\"},{\"image_url\":\"https://images.unsplash.com/photo-1519681393784-d120267933ba?w=400&auto=format&fit=crop&q=80\",\"contributor\":\"Benjamin Voros\"},{\"image_url\":\"https://images.unsplash.com/photo-147592415