{
  "name": "Emoji Picker",
  "use_bubble_size": true,
  "events": ["emoji_selected"],
  "properties": {
    "initial_emoji": {
      "type": "text",
      "default": ""
    },
    "search_placeholder": {
      "type": "text",
      "default": "Search..."
    },
    "return_format": {
      "type": "dropdown",
      "options": ["emoji", "hexcode", "shortcode"],
      "default": "emoji"
    }
  }
}
