{
  "name": "Avatar",
  "events": ["is_clicked"],
  "properties": {
    "username": {
      "type": "text",
      "default": ""
    },
    "image_url": {
      "type": "text",
      "default": ""
    },
    "style": {
      "type": "dropdown",
      "options": ["serif", "sans serif", "monospace"],
      "default": "sans serif"
    },
    "text_color": {
      "type": "text",
      "default": "#333333"
    },
    "background_color": {
      "type": "text",
      "default": "#e5e7eb"
    }
  }
}
