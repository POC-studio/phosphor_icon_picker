{
  "name": "Slider Button",
  "use_bubble_size": true,
  "events": ["button_slided", "button_dragged"],
  "states": {
    "drag_completion_percent": {
      "type": "number",
      "label": "Slide completion (%)"
    }
  },
  "actions": [
    {
      "id": "reset_button",
      "label": "Reset button",
      "type": "run_script",
      "file": "actions/reset-button.js"
    }
  ],
  "properties": {
    "text": {
      "type": "text",
      "default": "Slide to confirm"
    },
    "default_color": {
      "type": "color",
      "default": "#ef4444"
    },
    "success_color": {
      "type": "color",
      "default": "#22c55e"
    },
    "hold_duration_ms": {
      "type": "integer",
      "default": 500
    },
    "border_radius": {
      "type": "integer",
      "default": 9999
    },
    "padding": {
      "type": "integer",
      "default": 0
    }
  }
}
